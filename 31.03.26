5]create or replace procedure to_mth
as
v_month varchar2(10);
begin
v_month:=upper(to_char(sysdate, 'day'));
dbms_output.put_line('the current month is' || v_month);
end;
/

Procedure created.

SQL> exec to_mth;
the current month isTUESDAY

PL/SQL procedure successfully completed.
